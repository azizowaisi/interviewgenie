# syntax=docker/dockerfile:1.6
# Production-style image (also used for local full-stack compose).
# Node 22 LTS on Alpine — official Node images are Debian/Alpine-based (not Ubuntu).
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* .npmrc ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
# Baked at build — override per environment (local vs production) via compose / CI build-args.
ARG NEXT_PUBLIC_PUBLIC_APP_URL=http://localhost:3002
ARG NEXT_PUBLIC_SITE_URL=
ARG NEXT_PUBLIC_ADMIN_SITE_URL=
ARG NEXT_PUBLIC_ADMIN_HOSTS=
ARG NEXT_PUBLIC_MAIN_APP_HOSTS=
ARG NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON=
ARG NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC=
ARG NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN=
ARG NEXT_PUBLIC_DESKTOP_DOWNLOAD_LINUX=
ARG NEXT_PUBLIC_DESKTOP_DOWNLOADS_PAGE=
ARG NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=
ARG AUTH0_DOMAIN=
ARG AUTH0_ISSUER_BASE_URL=
ARG AUTH0_CLIENT_ID=
ARG AUTH0_CLIENT_SECRET=
ARG AUTH0_SECRET=
ARG AUTH0_BASE_URL=http://localhost:3002
ARG APP_BASE_URL=http://localhost:3002
ENV NEXT_PUBLIC_PUBLIC_APP_URL=$NEXT_PUBLIC_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_ADMIN_SITE_URL=$NEXT_PUBLIC_ADMIN_SITE_URL
ENV NEXT_PUBLIC_ADMIN_HOSTS=$NEXT_PUBLIC_ADMIN_HOSTS
ENV NEXT_PUBLIC_MAIN_APP_HOSTS=$NEXT_PUBLIC_MAIN_APP_HOSTS
ENV NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON=$NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON
ENV NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC=$NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC
ENV NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN=$NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN
ENV NEXT_PUBLIC_DESKTOP_DOWNLOAD_LINUX=$NEXT_PUBLIC_DESKTOP_DOWNLOAD_LINUX
ENV NEXT_PUBLIC_DESKTOP_DOWNLOADS_PAGE=$NEXT_PUBLIC_DESKTOP_DOWNLOADS_PAGE
ENV NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=$NEXT_PUBLIC_DESKTOP_INSTALLER_BASE
ENV AUTH0_DOMAIN=$AUTH0_DOMAIN
ENV AUTH0_ISSUER_BASE_URL=$AUTH0_ISSUER_BASE_URL
ENV AUTH0_CLIENT_ID=$AUTH0_CLIENT_ID
ENV AUTH0_CLIENT_SECRET=$AUTH0_CLIENT_SECRET
ENV AUTH0_SECRET=$AUTH0_SECRET
ENV AUTH0_BASE_URL=$AUTH0_BASE_URL
ENV APP_BASE_URL=$APP_BASE_URL
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3002
ENV HOSTNAME=0.0.0.0
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3002
CMD ["node", "server.js"]
