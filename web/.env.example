# Local dev: `next.config.ts` loads repo-root `.env` then `web/` env files (`.env.local` overrides).
#
# Auth0 + middleware: put the same Auth0 variables in **`web/.env.local`** (copy from below) if `/auth/login`
# still says "Sign-in is not configured" while root `.env` is filled — Edge middleware reads `web/` env first.
#
# --- Public site URL (local vs production) ---
# Use the same origin you type in the browser. Set for both dev and prod; Docker/CI bake NEXT_PUBLIC_* at build.
# Primary:
# NEXT_PUBLIC_PUBLIC_APP_URL=http://localhost:3002
# Optional alias (same value as NEXT_PUBLIC_PUBLIC_APP_URL if set):
# NEXT_PUBLIC_SITE_URL=
# Auth0 application URL must match (see AUTH0_BASE_URL below). APP_BASE_URL is supported as a fallback for server code.
#
# Host-based routing (optional; only if you use separate admin vs main hostnames):
# NEXT_PUBLIC_MAIN_APP_HOSTS=example.com,www.example.com
# NEXT_PUBLIC_ADMIN_HOSTS=admin.example.com
# NEXT_PUBLIC_ADMIN_SITE_URL=https://admin.example.com

# Interview Genie API (FastAPI) — proxied as /api/app/*
API_URL=http://127.0.0.1:8001
# NEXT_PUBLIC_API_URL=http://132.226.198.193:8001

# Audio service (mock questions / evaluate) — proxied as /api/audio/*
AUDIO_URL=http://127.0.0.1:8000

# Monitoring service (K8s admin API) — proxied as /api/mon/*
MONITORING_URL=http://127.0.0.1:3001
# Optional: if monitoring enforces ADMIN_TOKEN
MONITORING_ADMIN_TOKEN=

# Auth0 (Login / Signup)
# If set, the website will require login for interview/upload/mock/history/result flows.
# Configure these in production and local dev (via Auth0 application settings).
# Auth0 tenant domain (without protocol), e.g. your-tenant.us.auth0.com
AUTH0_DOMAIN=
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3002
# Optional if AUTH0_DOMAIN is set (kept for compatibility with existing setups)
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Browser can read this to show defaults in docs (optional)
# NEXT_PUBLIC_AUDIO_URL=
# NEXT_PUBLIC_MONITORING_URL=

# Desktop app downloads (baked at `next build`)
# Production: keep installers off the web Docker image. CI workflow `.github/workflows/desktop-installers.yml`
# builds them and can rsync to a separate volume; point these URLs at that static host (or CDN).
# The desktop app calls GET {site}/desktop-latest.json (from `web/public/desktop-latest.json`) to compare versions;
# bump `version` (and optionally `minVersion`) there when you ship a new installer. Override fetch URL with env
# INTERVIEWGENIE_UPDATE_MANIFEST_URL in the Electron build if the manifest lives only on your download host.
# Local dev: put files in web/public/desktop/ (npm run desktop:publish-web) — served as /desktop/* when present.
# Option A — single JSON:
# NEXT_PUBLIC_DESKTOP_DOWNLOADS_JSON={"mac":"https://cdn.example.com/InterviewGenie.dmg","win":"https://cdn.example.com/InterviewGenie.exe","linux":"https://cdn.example.com/InterviewGenie.AppImage","releasesPage":"https://github.com/org/repo/releases"}
# Option B — per-OS URLs (optional releases page):
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC=
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN=
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_LINUX=
# NEXT_PUBLIC_DESKTOP_DOWNLOADS_PAGE=
#
# Option C — same folder on any host (no trailing slash): fills mac/win/linux using fixed filenames
# NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=https://your-site.example.com/desktop
# If unset, the app may derive .../desktop from NEXT_PUBLIC_PUBLIC_APP_URL / AUTH0_BASE_URL (see lib/desktop-downloads.ts).
# Local Docker (same host as the app): NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=http://localhost:3002/desktop
