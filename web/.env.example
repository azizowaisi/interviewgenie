# Interview Genie API (FastAPI) — proxied as /api/app/*
API_URL=http://127.0.0.1:8001
# NEXT_PUBLIC_API_URL=http://132.226.198.193:8001

# Audio service (mock questions / evaluate) — proxied as /api/audio/*
AUDIO_URL=http://127.0.0.1:8000

# Monitoring service (K8s admin API) — proxied as /api/mon/*
MONITORING_URL=http://127.0.0.1:3001
# Optional: if monitoring enforces ADMIN_TOKEN
MONITORING_ADMIN_TOKEN=

# Browser can read this to show defaults in docs (optional)
# NEXT_PUBLIC_AUDIO_URL=
# NEXT_PUBLIC_MONITORING_URL=

# Host routing (baked at `next build` in Docker — see Dockerfile ARGs)
# NEXT_PUBLIC_ADMIN_HOSTS=admin.interviewgenie.teckiz.com
# NEXT_PUBLIC_PUBLIC_APP_URL=https://interviewgenie.teckiz.com
# NEXT_PUBLIC_ADMIN_SITE_URL=https://admin.interviewgenie.teckiz.com
# NEXT_PUBLIC_MAIN_APP_HOSTS=interviewgenie.teckiz.com,www.interviewgenie.teckiz.com
