{
  "name": "interview-genie-desktop",
  "version": "0.1.0",
  "description": "AI Real-Time Interview Assistant - Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.interviewgenie.desktop",
    "productName": "Interview Genie",
    "directories": { "output": "dist" },
    "linux": { "target": ["appimage"] },
    "mac": { "target": ["dmg"], "category": "public.app-category.productivity" },
    "win": { "target": ["nsis"] }
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
