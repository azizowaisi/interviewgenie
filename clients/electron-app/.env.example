INTERVIEWGENIE_API_BASE=https://interviewgenie.teckiz.com/api/svc
INTERVIEWGENIE_AUDIO_BASE=https://interviewgenie.teckiz.com/api/audio
INTERVIEWGENIE_WS_URL=wss://interviewgenie.teckiz.com/ws/audio

# Optional: JSON manifest for update nag (default: {origin of API base}/desktop-latest.json)
# INTERVIEWGENIE_UPDATE_MANIFEST_URL=https://your.cdn.example/desktop-latest.json

# Auth0 (Desktop Native App)
# Use the Native Application client ID from Auth0.
INTERVIEWGENIE_AUTH0_CLIENT_ID=
INTERVIEWGENIE_AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
INTERVIEWGENIE_AUTH0_CALLBACK_URL=http://127.0.0.1:9090/auth/callback
INTERVIEWGENIE_AUTH0_AUDIENCE=

# Optional fallback when not logged in
INTERVIEWGENIE_USER_ID=default
