# Optional: always merge the local overlay when you run plain `docker compose`
# from the repo root (otherwise use npm run local:up).
# COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# Production / remote (example — use your real hosts)
# API_URL=https://api.example.com
# AUDIO_URL=https://audio.example.com
# MONITORING_URL=https://monitoring.example.com
# MONITORING_ADMIN_TOKEN=secret-if-required

# Auth0 (shared tenant)
# Set these for web app login and desktop login.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com

# Website (Next.js Regular Web App credentials)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
# Must match the URL you use in the browser (and Auth0 callback / logout URLs).
AUTH0_BASE_URL=http://localhost:3002
APP_BASE_URL=http://localhost:3002
# Baked into the client bundle at `docker compose build` — set for production builds:
# NEXT_PUBLIC_PUBLIC_APP_URL=https://your-production-domain.example.com
# NEXT_PUBLIC_SITE_URL=
# Optional host routing (admin on a subdomain): NEXT_PUBLIC_ADMIN_HOSTS= NEXT_PUBLIC_ADMIN_SITE_URL= NEXT_PUBLIC_MAIN_APP_HOSTS=

# Desktop download buttons on the Next.js site (baked at `docker compose --build` for `web`)
# Point at the folder that serves InterviewGenie-macos.dmg, InterviewGenie-windows.exe, InterviewGenie-linux.AppImage
# Option A (production): same host as your public site, /desktop path
NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=https://your-site.example.com/desktop
# Local (all three files in web/public/desktop/): NEXT_PUBLIC_DESKTOP_INSTALLER_BASE=http://localhost:3002/desktop

# Desktop (Electron Native App credentials)
INTERVIEWGENIE_AUTH0_CLIENT_ID=
INTERVIEWGENIE_AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
INTERVIEWGENIE_AUTH0_CALLBACK_URL=http://127.0.0.1:9090/auth/callback
# Production example:
# INTERVIEWGENIE_AUTH0_CALLBACK_URL=https://your-desktop-callback.example.com/auth/callback
INTERVIEWGENIE_AUTH0_AUDIENCE=
